<mujoco model="go2_tracking">
  <!-- Meshes live in assets/assets/; paths resolve from this file (sim/) -->
  <compiler meshdir="assets/assets" autolimits="true"/>
  <include file="assets/go2.xml"/>

  <!-- Bump MuJoCo's stack/jacobian memory to accommodate 2000+ obstacle
       mocaps in the scene (broadphase needs ~4 KB per active geom). -->
  <size memory="256M"/>

  <statistic center="0 0 0.3" extent="3.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.2 0.3 0.4 1"/>
    <global azimuth="-150" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.05 0.05 0.15"
      width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.85 0.85 0.80" rgb2="0.60 0.60 0.55" markrgb="0.9 0.9 0.9"
      width="400" height="400"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
      texrepeat="6 6" reflectance="0.08"/>
    <!-- Glowing red ball: emissive so it reads as the focal point -->
    <material name="ball_mat" rgba="0.95 0.10 0.12 1" emission="0.6"
              specular="0.85" shininess="0.6"/>
    <!-- Wall: warm concrete tone, slightly reflective -->
    <material name="wall_mat" rgba="0.42 0.36 0.31 1" reflectance="0.04"/>
    <!-- TALL obstacles: clean deep slate (modern industrial look) -->
    <material name="obstacle_mat" rgba="0.165 0.180 0.230 1"
              specular="0.4" shininess="0.45" reflectance="0.05"/>
    <!-- SHORT obstacles: warm orange/coral, clean solid color -->
    <material name="short_obstacle_mat" rgba="0.92 0.42 0.20 1"
              specular="0.5" shininess="0.45" reflectance="0.05"/>
  </asset>

  <worldbody>
    <!-- Lighting -->
    <light name="sun" pos="0 0 4" dir="0 0 -1" directional="true"
      diffuse="0.7 0.7 0.7" specular="0.1 0.1 0.1"/>
    <light name="fill" pos="-3 -3 4" dir="0.5 0.5 -1" directional="false"
      diffuse="0.25 0.25 0.25" specular="0 0 0"/>

    <!-- Ground plane -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"
      friction="0.8 0.005 0.0001"/>

    <!-- Corridor walls: 5 m wide (y=±2.58), 600 m long. -->
    <geom name="corridor_wall_north" type="box" size="300.0 0.08 0.5"
          pos="297.0  2.58 0.5" material="wall_mat"/>
    <geom name="corridor_wall_south" type="box" size="300.0 0.08 0.5"
          pos="297.0 -2.58 0.5" material="wall_mat"/>
    <!-- Back wall so robot doesn't wander off behind -->
    <geom name="corridor_wall_back"  type="box" size="0.08 2.7 0.5"
          pos="-3.08 0 0.5" material="wall_mat"/>

    <!-- Target ball (mocap = kinematically controlled via data.mocap_pos in Python).
         Ball is defined BEFORE obstacles so its mocap index stays at 0. -->
    <body name="target_ball" mocap="true" pos="2.0 0.0 0.15">
      <geom name="ball" type="sphere" size="0.13" material="ball_mat"
        contype="0" conaffinity="0"/>
    </body>

    <!-- 100 VARIED OBSTACLES: y-widths 0.30-1.90 m,
         alternating tall (black, 0.40 m high) and short (orange, 0.12 m high). -->

    <body name="varied_obs_1" mocap="true" pos="100 100 -5">
      <geom name="vobs_1" type="box" size="0.20 0.506 0.4" material="obstacle_mat" contype="1" conaffinity="1"/>
    </body>
